generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  name       String
  role       Role     @default(HR)
  totalDays  Int      @default(15)  // jild olgoh total udur
  usedDays   Int      @default(0)
  createdAt  DateTime @default(now()) //burtguulsen ognoo

  requests   LeaveRequest[]
}

enum Role {
  ADMIN
  HR
  EMPLOYEE
}

model RequestType {
  id       Int            @id @default(autoincrement())
  name     String
  limit    Int
  period   Period         @default(YEARLY)
  requests LeaveRequest[]
}

enum Period {
  YEARLY
  MONTHLY
}

model LeaveRequest {
  id            Int         @id @default(autoincrement())
  userId        Int  //huselt grgsn hun
  user          User        @relation(fields: [userId], references: [id])
  requestTypeId Int
  requestType   RequestType @relation(fields: [requestTypeId], references: [id])
  startDate     DateTime
  endDate       DateTime
  days          Int
  reason        String
  status        Status      @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}